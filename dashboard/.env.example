# Cyberspace Dashboard — Environment Variables
# Copy this file to .env and fill in values as needed.

# ─── Notion Integration ───────────────────────────────────────────────────────
# See setup.md in the project root for step-by-step setup instructions.
#
# Your Notion internal integration token (starts with "secret_")
# NOTION_TOKEN=secret_your_token_here
#
# The ID of the Notion database for tasks (UUID from the database URL)
# NOTION_DATABASE_ID=your-database-uuid-here

# ─── Google Calendar OAuth (Phase 2 — optional) ───────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# Server port (default: 3000)
PORT=3000
