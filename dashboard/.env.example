# Cyberspace Dashboard — Environment Variables
# Copy this file to .env and fill in values as needed.

# There is nothing that could be disclosed in here actually, ha!

# HTTP port — used when no TLS certs are present, or as the redirect listener when HTTPS is active (default: 3000)
HTTP_PORT=3000

# HTTPS port — used when TLS certificates are present in dashboard/certs/ (default: 4444)
HTTPS_PORT=4444

# Optional map center for dashboard startup (lat,lng)
MAP_CENTER=20,0
